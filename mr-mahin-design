}

}

</style>

</head>

<body>

<header>

<div class="logo">

Mr. Mahin'<span>Design</span>

</div>

<div class="admin" onclick="window.location.href='admin.html'">
ADMIN PANEL
</div>

</header>

<section class="hero">

<h1>Mr. Mahin</h1>

<p>Digital Marketer & AI Artist</p>

</section>

<div class="gallery" id="gallery">

</div>

<div class="buttons">

<a href="https://wa.me/8801602336111" class="btn whatsapp">

WHATSAPP

</a>

<a href="#" class="btn telegram">

TELEGRAM

</a>

</div>

<footer>

