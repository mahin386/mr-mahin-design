}

.buttons{

padding:25px;

}

.btn{

display:block;

text-decoration:none;

text-align:center;

padding:18px;

border-radius:50px;

margin-bottom:18px;

font-size:20px;

font-weight:bold;

}

.whatsapp{

background:#c6ff00;

color:black;

}

.telegram{

border:2px solid #333;

color:white;

}

footer{

text-align:center;

padding:40px;

color:#666;

}

@media(max-width:700px){

.hero h1{

font-size:40px;

}

.hero p{

