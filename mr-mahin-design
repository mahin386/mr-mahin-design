body{

background:#0d0d0d;
color:white;

}

header{

display:flex;
justify-content:space-between;
align-items:center;
padding:18px;

border-bottom:1px solid #222;

position:sticky;
top:0;
background:#0d0d0d;
z-index:999;

}

.logo{

font-size:22px;
font-weight:700;

}

.logo span{

color:#c6ff00;

}

.admin{

padding:10px 18px;

border:2px solid #c6ff00;

color:#c6ff00;

border-radius:40px;

cursor:pointer;

}

.hero{

padding:60px 20px;

text-align:center;

}

.hero h1{

font-size:52px;

}

.hero p{

